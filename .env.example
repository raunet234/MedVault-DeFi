# Hedera Testnet Credentials
HEDERA_ACCOUNT_ID=0.0.XXXXX
HEDERA_PRIVATE_KEY=your_hedera_private_key_here
HEDERA_NETWORK=testnet

# IPFS (Web3.Storage or Pinata)
IPFS_API_KEY=your_ipfs_api_key_here
IPFS_API_SECRET=your_ipfs_api_secret_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Backend
PORT=5000
FRONTEND_URL=http://localhost:5173

# Deployed Contract Addresses (filled after deployment)
VERIFICATION_ESCROW_ADDRESS=
DOCTOR_REGISTRY_ADDRESS=
DATA_MARKETPLACE_ADDRESS=
PATIENT_CONSENT_ADDRESS=

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
